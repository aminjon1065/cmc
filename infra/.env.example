# --- Copy this file to infra/.env and adjust as needed ---
# `infra/.env` is git-ignored.

# ---------- Postgres ----------
POSTGRES_USER=cmc
POSTGRES_PASSWORD=cmc_dev_password_change_me
POSTGRES_DB=cmc
POSTGRES_PORT=5432

# ---------- Redis ----------
REDIS_PORT=6379
REDIS_PASSWORD=cmc_dev_redis_change_me

# ---------- MinIO ----------
MINIO_ROOT_USER=cmc-admin
MINIO_ROOT_PASSWORD=cmc_dev_minio_change_me
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_DEFAULT_BUCKETS=cmc-files,cmc-backups

# ---------- Postgres backups (P0.5 / ADR-0012) ----------
# The postgres-backup sidecar runs pg_dump on this schedule and uploads to
# BACKUP_BUCKET; objects older than BACKUP_RETENTION_DAYS are pruned.
# Set BACKUP_RUN_ON_START=true to also dump immediately when the container
# starts (useful for the first run / smoke test).
BACKUP_BUCKET=cmc-backups
BACKUP_RETENTION_DAYS=7
BACKUP_SCHEDULE_CRON=0 3 * * *
BACKUP_RUN_ON_START=false
BACKUP_TZ=UTC
