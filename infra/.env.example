# --- Copy this file to infra/.env and adjust as needed ---
# `infra/.env` is git-ignored.

# ---------- Postgres ----------
POSTGRES_USER=cmc
POSTGRES_PASSWORD=cmc_dev_password_change_me
POSTGRES_DB=cmc
POSTGRES_PORT=5432

# ---------- Redis ----------
REDIS_PORT=6379
REDIS_PASSWORD=cmc_dev_redis_change_me

# ---------- MinIO ----------
MINIO_ROOT_USER=cmc-admin
MINIO_ROOT_PASSWORD=cmc_dev_minio_change_me
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_DEFAULT_BUCKETS=cmc-files,cmc-backups
# Audit Merkle-anchor bucket (P1.11b / ADR-0029) — created WITH Object Lock by
# minio-init (separate from the list above; lock can't be enabled later).
AUDIT_ANCHOR_BUCKET=cmc-audit-anchors

# NATS JetStream — the event plane (P2.1 / ADR-0031).
NATS_PORT=4222
NATS_MONITOR_PORT=8222

# ClickHouse — analytical store (P2.5 / ADR-0033). Only HTTP (8123) is published.
CLICKHOUSE_DB=cmc
CLICKHOUSE_USER=cmc
CLICKHOUSE_PASSWORD=cmc_dev_clickhouse_change_me
CLICKHOUSE_HTTP_PORT=8123

# GeoServer — OGC GIS server (ADR-0079): QGIS/ArcGIS/web share PostGIS via
# WMS/WFS. Change the admin password in prod (and front with Caddy). The
# read-only `geoserver_ro` DB role + password live in postgres/init/02-roles.sql
# and geoserver/setup.sh.
GEOSERVER_PORT=8088
GEOSERVER_ADMIN_USER=admin
GEOSERVER_ADMIN_PASSWORD=cmc_dev_geoserver_admin_change_me

# ---------- Postgres backups (P0.5 / ADR-0012) ----------
# The postgres-backup sidecar runs pg_dump on this schedule and uploads to
# BACKUP_BUCKET; objects older than BACKUP_RETENTION_DAYS are pruned.
# Set BACKUP_RUN_ON_START=true to also dump immediately when the container
# starts (useful for the first run / smoke test).
BACKUP_BUCKET=cmc-backups
BACKUP_RETENTION_DAYS=7
BACKUP_SCHEDULE_CRON=0 3 * * *
BACKUP_RUN_ON_START=false
BACKUP_TZ=UTC
