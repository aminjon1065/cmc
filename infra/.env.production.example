# --- Copy to infra/.env.production and fill in for an external deployment ---
# `infra/.env.production` is git-ignored. Used by the deploy overlay
# (infra/deploy-compose.yml) which builds + runs the api + web images behind
# Caddy (P0.9 / ADR-0016, P0.10 / ADR-0017) via `pnpm deploy:up`.
#
# Bring the core data services up first:  pnpm infra:up   (Postgres/Redis/MinIO
# on the shared cmc-net network) — the API joins it to reach them by name.

# ---------- Hostnames (REQUIRED) ----------
# The public domains Caddy serves. Caddy auto-provisions a Let's Encrypt
# certificate for each — point both A/AAAA records at this host first. For a
# LOCAL TLS smoke test use the *.localhost names (Caddy's internal CA, no ACME):
#   APP_HOST=localhost
#   API_HOST=api.localhost
APP_HOST=app.example.com
API_HOST=api.example.com

# ---------- Secrets (REQUIRED) ----------
# Generate each with:  node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=change_me_to_a_long_random_string_at_least_32_chars
AUTH_SECRET=change_me_to_a_long_random_string_at_least_32_chars

# ---------- ACME ----------
# Email for Let's Encrypt expiry / policy notices. Unused for *.localhost.
CADDY_ACME_EMAIL=admin@example.com
# Optional: use the LE STAGING CA while testing to avoid rate limits.
#   CADDY_EXTRA_GLOBAL=acme_ca https://acme-staging-v02.api.letsencrypt.org/directory
CADDY_EXTRA_GLOBAL=

# ---------- Upstreams (optional overrides) ----------
# Default to the compose service names (api + web run in the deploy overlay as
# of P0.10). Override only for a transitional host-run app:
#   APP_UPSTREAM=host.docker.internal:3000
#   API_UPSTREAM=host.docker.internal:3001
# APP_UPSTREAM=web:3000
# API_UPSTREAM=api:3001

# ---------- Data services (optional overrides) ----------
# Defaults assume the core stack on cmc-net with the dev passwords. CHANGE these
# for a real deploy (rotate the Postgres / Redis / MinIO credentials too).
# DATABASE_URL=postgresql://cmc_app:STRONG_PW@postgres:5432/cmc
# DATABASE_OWNER_URL=postgresql://cmc:STRONG_PW@postgres:5432/cmc
# REDIS_URL=redis://:STRONG_PW@redis:6379
# S3_ENDPOINT=http://minio:9000
# S3_ACCESS_KEY=cmc-admin
# S3_SECRET_KEY=STRONG_PW
# S3_BUCKET_FILES=cmc-files

# ---------- Optional ----------
# OTLP traces collector (unset = create spans, export nothing — no noise).
# OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4318
