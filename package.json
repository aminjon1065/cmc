{
  "name": "cmc",
  "version": "0.0.0",
  "private": true,
  "description": "Unified Enterprise Operational Intelligence Platform — monorepo root",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "infra:up": "docker compose -f infra/docker-compose.yml --env-file infra/.env up -d",
    "infra:down": "docker compose -f infra/docker-compose.yml --env-file infra/.env down",
    "infra:logs": "docker compose -f infra/docker-compose.yml --env-file infra/.env logs -f",
    "infra:reset": "docker compose -f infra/docker-compose.yml --env-file infra/.env down -v",
    "infra:ps": "docker compose -f infra/docker-compose.yml --env-file infra/.env ps",
    "db:backup": "docker compose -f infra/docker-compose.yml --env-file infra/.env exec -T postgres-backup /usr/local/bin/backup.sh",
    "db:restore": "docker compose -f infra/docker-compose.yml --env-file infra/.env exec -e CONFIRM_RESTORE postgres-backup /usr/local/bin/restore.sh",
    "obs:up": "docker compose -f infra/observability-compose.yml --env-file infra/.env up -d",
    "obs:down": "docker compose -f infra/observability-compose.yml --env-file infra/.env down",
    "obs:logs": "docker compose -f infra/observability-compose.yml --env-file infra/.env logs -f",
    "obs:reset": "docker compose -f infra/observability-compose.yml --env-file infra/.env down -v",
    "obs:ps": "docker compose -f infra/observability-compose.yml --env-file infra/.env ps",
    "deploy:up": "docker compose -f infra/deploy-compose.yml --env-file infra/.env.production up -d",
    "deploy:down": "docker compose -f infra/deploy-compose.yml --env-file infra/.env.production down",
    "deploy:logs": "docker compose -f infra/deploy-compose.yml --env-file infra/.env.production logs -f",
    "deploy:ps": "docker compose -f infra/deploy-compose.yml --env-file infra/.env.production ps",
    "deploy:validate": "docker run --rm -v \"$PWD/infra/caddy/Caddyfile:/etc/caddy/Caddyfile:ro\" -e APP_HOST=localhost -e API_HOST=api.localhost -e APP_UPSTREAM=localhost:3000 -e API_UPSTREAM=localhost:3001 -e CADDY_ACME_EMAIL=admin@example.com caddy:2.8-alpine caddy validate --config /etc/caddy/Caddyfile"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "prettier": "^3.4.2",
    "@types/node": "^25.9.3"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
