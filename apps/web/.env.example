# Public — exposed to the browser. Do not put secrets here.
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# Private — server-only.
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=change_me_to_a_long_random_string_at_least_32_chars
# Set if running behind a proxy or in a container (lets Auth.js trust the Host header).
AUTH_TRUST_HOST=true

# Server-side base URL for the NestJS API (called from Auth.js authorize()).
# Defaults to NEXT_PUBLIC_API_BASE_URL if unset.
API_BASE_URL=http://localhost:3001

# --- GIS map basemap (P2.9 / ADR-0039) ---
# The /map page needs a basemap. With nothing set it uses theme-aware CARTO
# raster tiles (light/dark), which require internet from the browser and show
# the © OpenStreetMap © CARTO attribution. To self-host / go fully offline,
# set ONE of these (vector style wins if both are set):
#   NEXT_PUBLIC_MAP_STYLE_URL  — a full MapLibre vector style JSON URL
#                                (e.g. a self-hosted or MapTiler style).
#   NEXT_PUBLIC_MAP_RASTER_URL — a single raster XYZ template used for both
#                                themes, e.g. https://tile.openstreetmap.org/{z}/{x}/{y}.png
# NEXT_PUBLIC_MAP_STYLE_URL=
# NEXT_PUBLIC_MAP_RASTER_URL=

# --- GIS overlay source (ADR-0079, Phase 3) ---
# Where the /map page gets its GIS layers:
#   geoserver (default) — server-rendered WMS rasters from GeoServer (same look
#                         as QGIS/ArcGIS), via the same-origin BFF /api/gis/wms.
#                         Requires GeoServer up (see infra/geoserver).
#   mvt                 — client-rendered vector tiles from the API (no GeoServer).
# NEXT_PUBLIC_GIS_SOURCE=geoserver
# NEXT_PUBLIC_GEOSERVER_WORKSPACE=cmc
# Server-only: how the BFF reaches GeoServer (browser never hits it directly).
# Dev default http://localhost:8088/geoserver; in a container use the service name.
# GEOSERVER_URL=http://localhost:8088/geoserver
# GEOSERVER_WORKSPACE=cmc
