# Public — exposed to the browser. Do not put secrets here.
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# Private — server-only.
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=change_me_to_a_long_random_string_at_least_32_chars
# Set if running behind a proxy or in a container (lets Auth.js trust the Host header).
AUTH_TRUST_HOST=true

# Server-side base URL for the NestJS API (called from Auth.js authorize()).
# Defaults to NEXT_PUBLIC_API_BASE_URL if unset.
API_BASE_URL=http://localhost:3001
