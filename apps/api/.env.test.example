# Copy to apps/api/.env.test (git-ignored). Used by `pnpm --filter @cmc/api test`.
#
# Tests run against a SEPARATE database (`cmc_test`) so a stray TRUNCATE
# never wipes dev data. The test global-setup creates the database,
# applies migrations, and grants cmc_app the same way init/02-roles.sql
# does for the dev DB.

NODE_ENV=test
PORT=3001
LOG_LEVEL=warn
CORS_ORIGINS=http://localhost:3000

DATABASE_URL=postgresql://cmc_app:cmc_app_dev_password_change_me@localhost:5432/cmc_test
DATABASE_OWNER_URL=postgresql://cmc:cmc_dev_password_change_me@localhost:5432/cmc_test

REDIS_URL=redis://:cmc_dev_redis_change_me@localhost:6379

S3_ENDPOINT=http://localhost:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=cmc-admin
S3_SECRET_KEY=cmc_dev_minio_change_me
S3_BUCKET_FILES=cmc-files
S3_FORCE_PATH_STYLE=true

JWT_SECRET=ci-test-jwt-secret-must-be-at-least-32-characters
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_SEC=2592000
JWT_ISSUER=cmc

# Auth rate limits — tightened for tests so the breach path runs in a
# few requests rather than hundreds, and the window expires fast enough
# that follow-up tests don't bleed into each other. The production
# defaults live in .env.example.
AUTH_LOGIN_IP_LIMIT=5
AUTH_LOGIN_IP_WINDOW_SEC=10
AUTH_LOGIN_EMAIL_LIMIT=3
AUTH_LOGIN_EMAIL_WINDOW_SEC=10
AUTH_REFRESH_IP_LIMIT=5
AUTH_REFRESH_IP_WINDOW_SEC=10

# Session cache TTL — production default is 900s. Tests use a short
# value so the TTL safety net is exercised within suite runtime; the
# invalidation paths (logout / revoke / family-burn / rotate) are
# what the spec asserts, not TTL expiry.
SESSION_CACHE_TTL_SEC=60

DOCUMENTS_MAX_UPLOAD_BYTES=104857600
DOCUMENTS_UPLOAD_URL_TTL_SEC=300
DOCUMENTS_DOWNLOAD_URL_TTL_SEC=300

# Seed values aren't used by tests — fixtures create their own users —
# but the config validator still requires them to be set.
SEED_TENANT_SLUG=test-default
SEED_TENANT_NAME="Test Tenant"
SEED_ADMIN_EMAIL=admin@test.local
SEED_ADMIN_PASSWORD=test_password_change_me
SEED_ADMIN_NAME="Test Admin"

# --- Observability / OpenTelemetry (P0.6 / ADR-0013) ---
# Tracing ON in tests (no exporter) so trace_id propagation is exercised:
# the suite asserts X-Trace-Id headers and trace_id on audit rows.
OTEL_ENABLED=true
OTEL_SERVICE_NAME=cmc-api-test
OTEL_TRACES_CONSOLE=false

# --- Metrics / Prometheus (P0.7 / ADR-0014) ---
METRICS_ENABLED=true

# The API's real metrics are prom-client (pull-based, scraped at /metrics by
# MetricsService). Independently of that, the OpenTelemetry NodeSDK started in
# src/tracing.ts auto-creates a metrics PeriodicExportingMetricReader whenever
# OTEL_METRICS_EXPORTER is unset — it silently defaults to "otlp". That reader's
# periodic timer fires AFTER jest tears down the worker, producing
# "Cannot log after tests are done" + "PeriodicExportingMetricReader: metrics
# export failed", which jest turns into a non-zero exit even when every test
# passed (false-red CI). "none" tells the SDK to skip the meter provider
# entirely; trace_id propagation — the only OTEL behaviour the suite asserts —
# is unaffected (it rides on span processors, not metrics).
OTEL_METRICS_EXPORTER=none

# --- Health probes (P0.8 / ADR-0015) ---
HEALTH_PROBE_TIMEOUT_MS=2000
