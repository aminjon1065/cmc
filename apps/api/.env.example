# Server
PORT=3001
NODE_ENV=development
LOG_LEVEL=debug

# CORS — comma-separated list of allowed origins for the web app and any tooling.
CORS_ORIGINS=http://localhost:3000

# --- Database ---
# Connection string used by both the API and the @cmc/db package for migrations.
DATABASE_URL=postgresql://cmc:cmc_dev_password_change_me@localhost:5432/cmc

# --- Redis ---
REDIS_URL=redis://:cmc_dev_redis_change_me@localhost:6379

# --- Object storage (MinIO / S3) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=cmc-admin
S3_SECRET_KEY=cmc_dev_minio_change_me
S3_BUCKET_FILES=cmc-files
S3_FORCE_PATH_STYLE=true
