# Server
PORT=3001
NODE_ENV=development
LOG_LEVEL=debug

# CORS — comma-separated list of allowed origins for the web app and any tooling.
CORS_ORIGINS=http://localhost:3000

# --- Database ---
# Runtime application URL — uses the `cmc_app` role which is non-superuser,
# non-BYPASSRLS, so RLS policies actually fire for it. Drizzle queries
# from the API connect with this URL.
DATABASE_URL=postgresql://cmc_app:cmc_app_dev_password_change_me@localhost:5432/cmc

# Owner URL — uses `cmc` (POSTGRES_USER, superuser). Used for migrations
# and the seed script, both of which legitimately bypass RLS to bootstrap
# rows that don't yet have a tenant context.
DATABASE_OWNER_URL=postgresql://cmc:cmc_dev_password_change_me@localhost:5432/cmc

# --- Redis ---
REDIS_URL=redis://:cmc_dev_redis_change_me@localhost:6379

# --- Secrets / Vault (P2.14 / ADR-0044) ---
# When true, the API fetches a KV v2 secret from Vault at boot and overlays its
# keys into the environment BEFORE validation (so MFA_ENC_KEY comes from Vault).
# OFF by default → pure env, no Vault needed. The dev compose runs Vault in dev
# mode (in-memory, root token) and seeds secret/cmc/api with MFA_ENC_KEY.
VAULT_ENABLED=false
VAULT_ADDR=http://localhost:8200
# Dev-mode root token (matches infra/docker-compose.yml). Prod: scoped AppRole /
# k8s-auth token, never a root token. Only required when VAULT_ENABLED=true.
VAULT_TOKEN=cmc_dev_vault_root
VAULT_KV_MOUNT=secret
VAULT_SECRET_PATH=cmc/api

# --- Durable workflows / Temporal (P3.1 / ADR-0045) ---
# When true, the API runs an in-process Temporal worker AND a real client (first
# workflow: per-case SLA-escalation timers). OFF by default → noop client, no
# worker, no Temporal needed. The dev compose runs Temporal (auto-setup, reusing
# Postgres) on :7233 + a Web UI on :8233.
TEMPORAL_ENABLED=false
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=cmc-main

# --- Incident-response workflow (P3.2 / ADR-0046) ---
# Auto-starts the Temporal incident-response workflow for incidents at/above this
# severity (1 = SEV-1, lower = more severe; default 2 → SEV-1 + SEV-2). It pages
# the assignee + reporter, reminds every interval while unacknowledged, and
# escalates to incident:resolve holders after the ack SLA. Gated by
# TEMPORAL_ENABLED. Durations in seconds.
INCIDENT_RESPONSE_SEVERITY_THRESHOLD=2
INCIDENT_ACK_SLA_SEC=900
INCIDENT_REMINDER_INTERVAL_SEC=300

# The outbox relay (P2.1b) publishes here; consumers subscribe. The outbox
# write side (P2.1a) is pure Postgres and needs no connection.

# The incident projection consumer (P2.5b) writes here. Off by default so dev

# --- Object storage (MinIO / S3) ---
# S3_ENDPOINT is what the API uses server-side. S3_PUBLIC_ENDPOINT is what
# pre-signed URLs given to the browser point at — usually the same in dev,
# different in prod (internal vs public DNS).
S3_ENDPOINT=http://localhost:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=cmc-admin
S3_SECRET_KEY=cmc_dev_minio_change_me
S3_BUCKET_FILES=cmc-files
S3_FORCE_PATH_STYLE=true

# --- Documents module limits ---
DOCUMENTS_MAX_UPLOAD_BYTES=104857600
# How long the pre-signed PUT URL is valid (seconds).
DOCUMENTS_UPLOAD_URL_TTL_SEC=300
# How long pre-signed GET (download) URLs are valid.
DOCUMENTS_DOWNLOAD_URL_TTL_SEC=300
# Versioning (P3.4): max object size to hash (SHA-256) at finalize; larger → null.
DOCUMENTS_HASH_MAX_BYTES=52428800
# Retention sweeper (P3.5): when true, a daily cron soft-deletes documents past
# their (inherited) retention, skipping legal-held ones. The manual
# /v1/documents/retention/sweep endpoint always runs. Off by default.
RETENTION_ENABLED=false

# --- Auth / JWT ---
# Use a long random string in production. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=change_me_to_a_long_random_string_at_least_32_chars
# Access token lifetime — short on purpose. The web auto-refreshes via the
# refresh token before this expires.
JWT_ACCESS_TTL=15m
# Refresh token lifetime. Single-use; rotated on every /auth/refresh call.
JWT_REFRESH_TTL_SEC=2592000
JWT_ISSUER=cmc

# --- Auth rate limits (P0.1 / ADR-0009) ---
# Fixed-window counters in Redis. The IP limit guards against one host
# flooding login attempts; the email limit guards against distributed
# attacks targeting one account.
AUTH_LOGIN_IP_LIMIT=30
AUTH_LOGIN_IP_WINDOW_SEC=300
AUTH_LOGIN_EMAIL_LIMIT=5
AUTH_LOGIN_EMAIL_WINDOW_SEC=900
AUTH_REFRESH_IP_LIMIT=60
AUTH_REFRESH_IP_WINDOW_SEC=300

# --- Session-active cache (P0.4 / ADR-0011) ---
# Redis-backed cache for "is this sid active?" short-circuits the
# per-request DB lookup in TenantContextMiddleware. Set close to the
# access-token lifetime (JWT_ACCESS_TTL in seconds) so a missed cache
# DEL adds zero exposure beyond the JWT's natural expiry. Default 900s
# (15 min) matches the JWT_ACCESS_TTL default of "15m".
SESSION_CACHE_TTL_SEC=900

# --- Observability / OpenTelemetry (P0.6 / ADR-0013) ---
# Tracing is ON by default. The exporter is gated on configuration:
#     (P1.8 adds a Tempo container, typically http://tempo:4318).
#   * With neither, spans are still created — trace_id flows into logs and
#     audit rows, W3C context propagates — but nothing is exported and
#     there is no connection-refused noise.
# by the SDK directly — no code change needed to tune them.

# so they're queryable in Grafana by request_id. Bring up the stack with

# --- Metrics / Prometheus (P0.7 / ADR-0014) ---
# Exposes GET /metrics (prom-client): HTTP RED histogram, DB transaction
# gauges, and Node process metrics. Scrape it with Prometheus
# (infra/observability-compose.yml). Set false to silence recording.
# /metrics is anonymous like /health — restrict it at the proxy (P0.9) in
# production; do not publish it to the public listener.
METRICS_ENABLED=true

# --- OpenAPI / API docs (P1.10 / ADR-0028) ---
# Builds the OpenAPI document at boot and serves it at GET /v1/openapi.json,
# gated behind a session + the `tenant:manage` permission (it describes the full
# admin surface). Swagger UI renders it in the web admin at /admin/api-docs.
# Set false to omit the document entirely (the route 404s).
OPENAPI_ENABLED=true

# --- Audit hash chain + Merkle anchoring (P1.11 / ADR-0029) ---
# Tamper-evidence over the append-only audit log. An async sealer fills each
# row's prev/this SHA256 hash within a per-(tenant, day) chain; a daily cron
# Merkle-roots each closed chain and writes the root to MinIO under Object Lock
# (WORM). AUDIT_SEAL_INTERVAL_SEC: sealer cadence (0 disables the timer; rows
# still seal on demand). AUDIT_ANCHOR_LOCK_MODE: GOVERNANCE (dev — a privileged
# user can override) or COMPLIANCE (immutable even to root until retention).
# The anchor bucket is created --with-lock by minio-init.
AUDIT_CHAIN_ENABLED=true
AUDIT_SEAL_INTERVAL_SEC=60
AUDIT_ANCHOR_ENABLED=true
AUDIT_ANCHOR_BUCKET=cmc-audit-anchors
AUDIT_ANCHOR_LOCK_MODE=GOVERNANCE
AUDIT_ANCHOR_RETENTION_DAYS=3650

# --- Audit SIEM export (P1.12 / ADR-0030) ---
# A worker tail-reads the audit log by `seq` cursor and ships each row as RFC
# 5424 syslog or CEF to a sink. ENABLED gates only the background interval — a
# manual POST /v1/audit/export/flush always runs. Default sink is `noop`
# (format-but-discard); set TRANSPORT=file|tcp + a destination to emit. Delivery
# is at-least-once (the SIEM dedups on the audit row id).
AUDIT_EXPORT_ENABLED=false
AUDIT_EXPORT_FORMAT=rfc5424
AUDIT_EXPORT_TRANSPORT=noop
AUDIT_EXPORT_FILE=./audit-export.log
AUDIT_EXPORT_TCP_HOST=localhost
AUDIT_EXPORT_TCP_PORT=514
AUDIT_EXPORT_INTERVAL_SEC=30
AUDIT_EXPORT_BATCH_SIZE=500

# --- Health probes (P0.8 / ADR-0015) ---
# /health (liveness, always 200) · /health/ready (pings Postgres+Redis+MinIO,
# 200 ready / 503 not_ready — for load balancers) · /health/deep
# (authenticated, per-dependency timings). This bounds each dependency probe
# so a hung dep can't hang the endpoint. Default 2000ms.
HEALTH_PROBE_TIMEOUT_MS=2000

# --- Initial seed (used by `pnpm seed` only) ---
SEED_TENANT_SLUG=default
SEED_TENANT_NAME="Default Tenant"
SEED_ADMIN_EMAIL=admin@cmc.local
SEED_ADMIN_PASSWORD=admin123456
SEED_ADMIN_NAME="Platform Admin"

# --- MFA / TOTP (P1.2 / ADR-0020) ---
# 32-byte base64 key encrypting TOTP secrets at rest (AES-256-GCM). The default
# is a PUBLIC dev key - MUST override in any real deploy (moves to Vault P2.14).
# Generate a real one with: openssl rand -base64 32
MFA_ENC_KEY=ZGV2LW1mYS1lbmNyeXB0aW9uLWtleS0zMmJ5dGVzISE=
# Lifetime of the short-lived mfa_token between the password and TOTP steps.
MFA_TOKEN_TTL_SEC=300
# Issuer label shown in the authenticator app.
MFA_ISSUER=CMC
# How many one-time backup codes to generate on enrolment.
MFA_BACKUP_CODE_COUNT=10

# --- Password reset (P1.3 / ADR-0021) ---
# Lifetime of a single-use reset token (seconds). Short by design.
PASSWORD_RESET_TTL_SEC=3600
# Base URL the self-service link embeds the token into (?token=...). The
# notifier delivers this; dev logs it, SMTP sends it at P1.6.
PASSWORD_RESET_URL_BASE=http://localhost:3000/reset-password
# Rate limits for the public reset endpoints. Per-email is the anti-spam
# control (each forgot may send a notification); per-IP bounds brute-force.
PASSWORD_RESET_IP_LIMIT=10
PASSWORD_RESET_IP_WINDOW_SEC=900
PASSWORD_RESET_EMAIL_LIMIT=3
PASSWORD_RESET_EMAIL_WINDOW_SEC=3600

# --- Email / SMTP (P1.6c / ADR-0024) ---
# Dev points at Mailpit (docker compose): SMTP localhost:1025, web UI :8025 —
# it catches all mail locally. Production points MAIL_* at a real SMTP server.
# When MAIL_ENABLED=false (or no host), MailService logs in dev / warns+drops
# in prod (reset links never hit prod stdout).
MAIL_ENABLED=true
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_SECURE=false
# MAIL_USER and MAIL_PASS are blank for Mailpit (no auth); set for real SMTP.
MAIL_USER=
MAIL_PASS=
MAIL_FROM=CMC <no-reply@cmc.local>
# Absolute base the API builds deep-links from in emails.
APP_BASE_URL=http://localhost:3000
