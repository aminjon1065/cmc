# Server
PORT=3001
NODE_ENV=development
LOG_LEVEL=debug

# CORS — comma-separated list of allowed origins for the web app and any tooling.
CORS_ORIGINS=http://localhost:3000

# --- Database ---
# Runtime application URL — uses the `cmc_app` role which is non-superuser,
# non-BYPASSRLS, so RLS policies actually fire for it. Drizzle queries
# from the API connect with this URL.
DATABASE_URL=postgresql://cmc_app:cmc_app_dev_password_change_me@localhost:5432/cmc

# Owner URL — uses `cmc` (POSTGRES_USER, superuser). Used for migrations
# and the seed script, both of which legitimately bypass RLS to bootstrap
# rows that don't yet have a tenant context.
DATABASE_OWNER_URL=postgresql://cmc:cmc_dev_password_change_me@localhost:5432/cmc

# --- Redis ---
REDIS_URL=redis://:cmc_dev_redis_change_me@localhost:6379

# --- Object storage (MinIO / S3) ---
# S3_ENDPOINT is what the API uses server-side. S3_PUBLIC_ENDPOINT is what
# pre-signed URLs given to the browser point at — usually the same in dev,
# different in prod (internal vs public DNS).
S3_ENDPOINT=http://localhost:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=cmc-admin
S3_SECRET_KEY=cmc_dev_minio_change_me
S3_BUCKET_FILES=cmc-files
S3_FORCE_PATH_STYLE=true

# --- Documents module limits ---
DOCUMENTS_MAX_UPLOAD_BYTES=104857600
# How long the pre-signed PUT URL is valid (seconds).
DOCUMENTS_UPLOAD_URL_TTL_SEC=300
# How long pre-signed GET (download) URLs are valid.
DOCUMENTS_DOWNLOAD_URL_TTL_SEC=300

# --- Auth / JWT ---
# Use a long random string in production. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=change_me_to_a_long_random_string_at_least_32_chars
# Access token lifetime — short on purpose. The web auto-refreshes via the
# refresh token before this expires.
JWT_ACCESS_TTL=15m
# Refresh token lifetime. Single-use; rotated on every /auth/refresh call.
JWT_REFRESH_TTL_SEC=2592000
JWT_ISSUER=cmc

# --- Initial seed (used by `pnpm seed` only) ---
SEED_TENANT_SLUG=default
SEED_TENANT_NAME="Default Tenant"
SEED_ADMIN_EMAIL=admin@cmc.local
SEED_ADMIN_PASSWORD=admin123456
SEED_ADMIN_NAME="Platform Admin"
